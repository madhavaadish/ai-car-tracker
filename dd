<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>APEX-07 Advanced RC Telemetry System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Rajdhani', sans-serif;
            background-color: #030712;
            color: #f3f4f6;
            overflow-x: hidden;
        }
        .hud-font {
            font-family: 'Orbitron', sans-serif;
        }
        /* Glassmorphism panel styling */
        .hud-panel {
            background: rgba(17, 24, 39, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(6, 182, 212, 0.2);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }
        @keyframes hazard-pulse {
            0%, 100% { opacity: 1; filter: drop-shadow(0 0 8px #ef4444); }
            50% { opacity: 0.3; }
        }
        .hazard-flash {
            animation: hazard-pulse 1s infinite linear;
        }
    </style>
</head>
<body class="min-h-screen relative flex flex-col justify-between">

    <div id="notificationContainer" class="fixed top-6 left-1/2 transform -translate-x-1/2 z-50 flex flex-col gap-3 w-full max-w-md px-4"></div>

    <header class="hud-panel border-b border-cyan-500/20 px-6 py-3 flex justify-between items-center z-30">
        <div class="flex items-center space-x-3">
            <span class="w-3.5 h-3.5 rounded-full bg-cyan-500 animate-pulse"></span>
            <h1 class="text-xl font-bold tracking-widest text-cyan-400 hud-font">APEX-07 // TELEMETRY</h1>
        </div>
        <div class="flex items-center space-x-4">
            <button id="lostFinderBtn" class="hidden bg-red-600/20 hover:bg-red-600 border border-red-500 text-red-200 text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded transition duration-200">
                🚨 Find Host (Play Tune)
            </button>
            <button id="serverCamToggleBtn" class="hidden bg-cyan-600/20 hover:bg-cyan-600/40 border border-cyan-500 text-cyan-400 text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded transition duration-200">
                📷 Toggle Preview
            </button>
            <div id="connectionStatus" class="text-xs bg-slate-800 px-3 py-1.5 rounded-md border border-slate-700 uppercase tracking-widest text-slate-400">
                Awaiting Connection Mode
            </div>
            <button id="settingsBtn" class="hidden text-slate-400 hover:text-cyan-400 transition-colors duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
            </button>
        </div>
    </header>

    <main id="onboardingScreen" class="flex-grow flex flex-col justify-center items-center px-4 py-12 z-20">
        <div class="hud-panel max-w-lg w-full p-8 rounded-xl border border-cyan-500/30 text-center space-y-6">
            <div class="space-y-2">
                <h2 class="text-3xl font-extrabold tracking-tight text-white uppercase hud-font">Register Mode</h2>
                <p class="text-sm text-slate-400">Initialize this terminal role within the APEX network layer.</p>
            </div>
            <div id="takeoverNotice" class="hidden bg-amber-500/10 border border-amber-500/30 rounded-lg p-4 text-center cursor-pointer hover:bg-amber-500/20 transition-all duration-300">
                <div class="text-sm font-bold text-amber-400 uppercase hud-font">Host is already made. Click here to transfer to you.</div>
            </div>
            <div id="monitorNotice" class="hidden bg-slate-900 border border-slate-700 rounded-lg p-4 text-left">
                <div class="flex items-start space-x-3">
                    <span class="flex h-3 w-3 mt-1 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                    </span>
                    <div>
                        <h4 class="text-sm font-bold text-slate-200 font-sans">Active host is online</h4>
                        <p class="text-xs text-slate-400 mt-1 font-sans">You may monitor streams passively or request takeover options.</p>
                    </div>
                </div>
            </div>
            <div class="space-y-4">
                <button id="registerHostBtn" class="w-full py-4 bg-cyan-600 hover:bg-cyan-700 text-slate-950 font-black tracking-widest text-lg uppercase rounded-lg transition-all duration-300 shadow-lg shadow-cyan-500/20 hud-font transform hover:-translate-y-0.5">
                    Register This Device as Host (Server)
                </button>
                <div class="text-slate-500 text-xs uppercase tracking-wider font-bold">or</div>
                <button id="registerMonitorBtn" class="w-full py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold tracking-wide rounded-lg border border-slate-700 transition duration-200">
                    Connect as Secondary Monitor (Client)
                </button>
            </div>
            <div id="passwordField" class="hidden space-y-3 pt-4 border-t border-slate-800 transition-all duration-300">
                <label id="passwordPromptLabel" class="block text-left text-xs text-cyan-400 tracking-wider uppercase font-bold">Security Credential Required</label>
                <input id="serverPassword" type="password" placeholder="Enter Password" class="w-full px-4 py-3 bg-slate-950 border border-slate-700 rounded-lg focus:outline-none focus:border-cyan-500 text-center text-lg hud-font text-white tracking-widest">
                <button id="confirmPasswordBtn" class="w-full py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-sm tracking-widest uppercase rounded-lg transition duration-200">
                    Verify Network Key
                </button>
            </div>
        </div>
    </main>

    <main id="cockpitScreen" class="hidden flex-grow flex flex-col z-10 overflow-hidden">
        <div class="w-full flex-grow relative bg-slate-950 flex flex-col justify-center items-center overflow-hidden min-h-[450px]">
            <div id="gearBanner" class="hidden absolute top-4 left-4 z-30 bg-red-600 text-white font-bold px-4 py-1.5 text-sm uppercase tracking-widest rounded shadow-lg animate-pulse">
                ⚠️ Car in Rear Gear
            </div>

            <div id="videoContainer" class="absolute inset-0 w-full h-full flex justify-center items-center z-0">
                <video id="webcamFeed" class="absolute inset-0 w-full h-full object-cover opacity-30" autoplay playsinline muted></video>
                <canvas id="cvOverlayCanvas" class="absolute inset-0 w-full h-full z-10 pointer-events-none"></canvas>
            </div>

            <div class="relative z-20 flex flex-col md:flex-row items-center justify-center gap-12 p-6 bg-slate-950/70 backdrop-blur-md rounded-2xl border border-cyan-500/30 shadow-2xl">
                <div class="flex flex-col items-center space-y-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-cyan-400 hud-font">Speedometer</span>
                    <canvas id="speedGauge" width="180" height="180" class="w-44 h-44"></canvas>
                    <div class="text-center">
                        <span id="currentSpeedText" class="text-3xl font-black hud-font text-white">0.0</span>
                        <span class="text-xs text-slate-400 uppercase tracking-wider ml-1">km/h</span>
                    </div>
                </div>

                <div class="flex flex-col items-center space-y-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-amber-400 hud-font">Tachometer</span>
                    <canvas id="rpmGauge" width="180" height="180" class="w-44 h-44"></canvas>
                    <div class="text-center">
                        <span id="rpmText" class="text-3xl font-black hud-font text-white">0</span>
                        <span class="text-xs text-slate-400 uppercase tracking-wider ml-1">RPM</span>
                    </div>
                </div>
            </div>

            <div class="absolute top-4 right-4 z-20 text-right space-y-1 bg-slate-900/80 p-2.5 rounded border border-slate-800 text-xs text-slate-400">
                <div>EST TOP SPEED: <span id="topSpeedValue" class="text-emerald-400 font-bold">4.9 km/h</span></div>
                <div>Role: <span id="roleIndicator" class="text-cyan-400 font-bold uppercase">Client</span></div>
                <div id="runTimerDisplay" class="text-cyan-400 font-bold hud-font">TIMER: 10.00s</div>
            </div>
        </div>

        <section class="hud-panel border-t border-slate-800 px-6 py-4 grid grid-cols-1 md:grid-cols-4 gap-4 z-20">
            <div class="bg-slate-900/50 p-3 rounded border border-slate-800/80 flex items-center justify-between">
                <div>
                    <span class="text-xs tracking-wider text-slate-400 uppercase block font-bold">IMU Alignment Status</span>
                    <span id="orientationStatus" class="text-base font-bold text-emerald-400 uppercase tracking-widest hud-font">Optimal</span>
                </div>
                <div class="text-right">
                    <div class="text-xs text-slate-400 font-medium">PITCH: <span id="pitchDisplay" class="text-white font-bold">0°</span></div>
                    <div class="text-xs text-slate-400 font-medium">ROLL: <span id="rollDisplay" class="text-white font-bold">0°</span></div>
                </div>
            </div>

            <div class="bg-slate-900/50 p-3 rounded border border-slate-800/80 flex flex-col justify-center">
                <div class="flex justify-between text-xs tracking-wider text-slate-400 uppercase mb-1 font-bold">
                    <span>Terrain Climbing</span>
                    <span id="climbChances" class="font-bold text-amber-400">100% Chances</span>
                </div>
                <div class="text-sm font-bold text-white tracking-wide">
                    INCLINE GRADIENT: <span id="inclineDisplay">0% Slope</span>
                </div>
            </div>

            <div class="bg-slate-900/50 p-3 rounded border border-slate-800/80 flex flex-col justify-center">
                <span class="text-xs tracking-wider text-slate-400 uppercase block mb-1 font-bold">Side Slide / Drift Vector</span>
                <div class="flex justify-between items-center">
                    <span id="slideStatus" class="text-sm font-bold text-white">Nominal Traction</span>
                    <span id="slideVector" class="text-xs text-cyan-400 font-semibold">[0.0G Lateral]</span>
                </div>
            </div>

            <div class="bg-slate-900/50 p-3 rounded border border-slate-800/80 flex flex-col justify-center">
                <span class="text-xs tracking-wider text-slate-400 uppercase block mb-1 font-bold">Tunnel Gap Passability</span>
                <div class="flex justify-between items-center">
                    <span id="passabilityText" class="text-sm font-bold text-emerald-400 uppercase tracking-wider">Detecting...</span>
                    <span id="dimensionTargetText" class="text-xs text-slate-400">Targeting: 15x20x5</span>
                </div>
            </div>
        </section>

        <section class="bg-slate-950 border-t border-slate-900 px-6 py-3 flex flex-wrap gap-4 items-center justify-between z-20">
            <span class="text-xs text-cyan-400 tracking-widest uppercase font-bold">Live Inputs:</span>
            <div class="flex items-center space-x-2">
                <button id="simFwd" class="px-3 py-1 bg-cyan-600 text-slate-950 text-xs font-bold uppercase rounded">Fwd</button>
                <button id="simRev" class="px-3 py-1 bg-slate-800 text-slate-400 text-xs font-bold uppercase rounded">Rev</button>
            </div>
            <div class="flex items-center space-x-2 text-xs">
                <label class="text-slate-400 font-bold">Pitch:</label>
                <input id="simPitch" type="range" min="-90" max="90" value="0" class="h-1 bg-slate-800 rounded appearance-none cursor-pointer w-20">
            </div>
            <div class="flex items-center space-x-2 text-xs">
                <label class="text-slate-400 font-bold">Roll:</label>
                <input id="simRoll" type="range" min="-180" max="180" value="0" class="h-1 bg-slate-800 rounded appearance-none cursor-pointer w-20">
            </div>
            <div class="flex items-center space-x-2 text-xs">
                <label class="text-slate-400 font-bold">Speed:</label>
                <input id="simSpeed" type="range" min="0" max="60" value="0" class="h-1 bg-slate-800 rounded appearance-none cursor-pointer w-24">
            </div>
            <div class="flex items-center space-x-2 text-xs">
                <label class="text-slate-400 font-bold">Obstacle:</label>
                <input id="simGap" type="range" min="5" max="50" value="25" class="h-1 bg-slate-800 rounded appearance-none cursor-pointer w-20">
            </div>
        </section>
    </main>

    <script>
        const myDeviceId = 'dev_' + Math.random().toString(36).substring(2, 11);
        const channel = new BroadcastChannel('rc_telemetry_channel');

        let state = {
            role: 'client', 
            isGearReverse: false,
            dimensions: { length: 15, width: 20, height: 5 },
            pitch: 0,
            roll: 0,
            currentSpeed: 0,
            topSpeed: 4.9,
            rpm: 0,
            cameraVisible: true 
        };

        let lastHostPingTimestamp = 0;
        let wakeLock = null;

        // UI Target Hooks
        const onboardingScreen = document.getElementById('onboardingScreen');
        const cockpitScreen = document.getElementById('cockpitScreen');
        const registerHostBtn = document.getElementById('registerHostBtn');
        const registerMonitorBtn = document.getElementById('registerMonitorBtn');
        const passwordField = document.getElementById('passwordField');
        const serverPassword = document.getElementById('serverPassword');
        const confirmPasswordBtn = document.getElementById('confirmPasswordBtn');
        const connectionStatus = document.getElementById('connectionStatus');
        const lostFinderBtn = document.getElementById('lostFinderBtn');
        const serverCamToggleBtn = document.getElementById('serverCamToggleBtn');
        const webcamFeed = document.getElementById('webcamFeed');

        // Canvas Gauges References
        const speedCtx = document.getElementById('speedGauge').getContext('2d');
        const rpmCtx = document.getElementById('rpmGauge').getContext('2d');

        // --- NATIVE SCREEN WAKE LOCK CONTROL (CRITICAL: Disables Dimming / No Battery Saver Mode) ---
        async function requestSystemWakeLock() {
            if ('wakeLock' in navigator) {
                try {
                    wakeLock = await navigator.wakeLock.request('screen');
                    triggerAlert('success', 'WakeLock Enabled: Battery saving sleep mode suppressed.');
                } catch (err) {
                    console.warn('System WakeLock Request Rejected:', err.message);
                }
            }
        }

        // --- WEB AUDIO API: SYNTHESIZED RETRO TUNE GENERATOR (For Host Localizer Beacon) ---
        function playHostFinderTune() {
            try {
                const AudioCtx = window.AudioContext || window.webkitAudioContext;
                if (!AudioCtx) return;
                const audioCtx = new AudioCtx();
                const notes = [523.25, 659.25, 783.99, 1046.50, 783.99, 1046.50];
                const durations = [0.15, 0.15, 0.15, 0.2, 0.15, 0.4];
                let time = audioCtx.currentTime;

                notes.forEach((freq, idx) => {
                    const osc = audioCtx.createOscillator();
                    const gain = audioCtx.createGain();
                    osc.type = 'square';
                    osc.frequency.setValueAtTime(freq, time);
                    gain.gain.setValueAtTime(0.3, time);
                    gain.gain.exponentialRampToValueAtTime(0.001, time + durations[idx]);
                    osc.connect(gain);
                    gain.connect(audioCtx.destination);
                    osc.start(time);
                    osc.stop(time + durations[idx]);
                    time += durations[idx] + 0.05;
                });
            } catch (e) {
                console.error("Audio playback error:", e);
            }
        }

        // --- REALTIME NOTIFICATION ALERTS HUB ---
        function triggerAlert(type, message) {
            const container = document.getElementById('notificationContainer');
            const alertBox = document.createElement('div');
            alertBox.className = `flex justify-between items-center px-4 py-3 rounded-lg border shadow-xl transition-all duration-300 text-sm font-bold bg-slate-900 border-cyan-500 text-white`;
            alertBox.innerHTML = `<div><span class="text-cyan-400">✦</span> ${message}</div>`;
            container.appendChild(alertBox);
            setTimeout(() => alertBox.remove(), 4000);
        }

        // --- NETWORK MESH LAYER DIRECT SYNCHRONIZATION ---
        channel.onmessage = (event) => {
            const data = event.data;
            if (data.type === 'HOST_PING') {
                lastHostPingTimestamp = Date.now();
            }
            if (data.type === 'TELEMETRY_SYNC' && state.role !== 'host') {
                state = { ...state, ...data.payload, role: state.role };
                syncDashboardUI();
            }
            if (data.type === 'TRIGGER_FINDER_TUNE' && state.role === 'host') {
                triggerAlert('warning', '🚨 REMOTE LOOKUP SIGNATURE RECEIVED! Playing locator beacon tune.');
                playHostFinderTune();
            }
        };

        setInterval(() => {
            if (state.role === 'host') {
                channel.postMessage({ type: 'HOST_PING' });
                channel.postMessage({ type: 'TELEMETRY_SYNC', payload: state });
            }
        }, 300);

        // --- CONTROLLER ACTIONS AND REGISTRATIONS ---
        registerHostBtn.addEventListener('click', () => {
            passwordField.classList.remove('hidden');
        });

        registerMonitorBtn.addEventListener('click', () => {
            state.role = 'client';
            document.getElementById('roleIndicator').innerText = "Client / Monitor";
            connectionStatus.innerText = "Connected to Host";
            lostFinderBtn.classList.remove('hidden'); 
            transitionToCockpit();
        });

        confirmPasswordBtn.addEventListener('click', () => {
            if (serverPassword.value === 'al007' || serverPassword.value === '') {
                state.role = 'host';
                document.getElementById('roleIndicator').innerText = "Server / Host";
                connectionStatus.innerText = "Server Active";
                serverCamToggleBtn.classList.remove('hidden'); 
                requestSystemWakeLock(); // Request wake lock to maintain persistent processing pipeline
                transitionToCockpit();
                initCamera();
            } else {
                triggerAlert('error', 'Passcode authorization failure.');
            }
        });

        lostFinderBtn.addEventListener('click', () => {
            triggerAlert('info', 'Ping packet dispatched to server device locator.');
            channel.postMessage({ type: 'TRIGGER_FINDER_TUNE' });
        });

        serverCamToggleBtn.addEventListener('click', () => {
            state.cameraVisible = !state.cameraVisible;
            webcamFeed.style.opacity = state.cameraVisible ? "0.3" : "0";
            triggerAlert('info', `Server Viewport Preview ${state.cameraVisible ? 'Enabled' : 'Disabled'}.`);
        });

        function transitionToCockpit() {
            onboardingScreen.classList.add('hidden');
            cockpitScreen.classList.remove('hidden');
            startGaugeRenderLoop();
        }

        async function initCamera() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: false });
                webcamFeed.srcObject = stream;
            } catch (err) {
                console.warn("Hardware camera sensor mapping unavailable.");
            }
        }

        // --- MANUAL SLIDER EMULATION INPUT HANDLERS ---
        document.getElementById('simFwd').addEventListener('click', () => {
            state.isGearReverse = false;
            document.getElementById('gearBanner').classList.add('hidden');
        });
        document.getElementById('simRev').addEventListener('click', () => {
            state.isGearReverse = true;
            document.getElementById('gearBanner').classList.remove('hidden');
        });
        document.getElementById('simPitch').addEventListener('input', (e) => {
            state.pitch = parseInt(e.target.value);
            document.getElementById('pitchDisplay').innerText = state.pitch + '°';
        });
        document.getElementById('simRoll').addEventListener('input', (e) => {
            state.roll = parseInt(e.target.value);
            document.getElementById('rollDisplay').innerText = state.roll + '°';
        });
        document.getElementById('simSpeed').addEventListener('input', (e) => {
            state.currentSpeed = parseFloat(e.target.value);
            state.rpm = Math.floor(state.currentSpeed * 120);
        });

        // --- DASHBOARD UI LAYER UPDATE HANDLERS ---
        function syncDashboardUI() {
            document.getElementById('currentSpeedText').innerText = state.currentSpeed.toFixed(1);
            document.getElementById('rpmText').innerText = state.rpm;
            document.getElementById('pitchDisplay').innerText = state.pitch + '°';
            document.getElementById('rollDisplay').innerText = state.roll + '°';
            
            const orientation = document.getElementById('orientationStatus');
            if (Math.abs(state.pitch) > 40 || Math.abs(state.roll) > 40) {
                orientation.innerText = "CRITICAL ANGLE";
                orientation.className = "text-base font-bold text-red-500 animate-pulse";
            } else {
                orientation.innerText = "OPTIMAL";
                orientation.className = "text-base font-bold text-emerald-400";
            }
        }

        // --- ARCS AND NEEDLES CANVAS RENDER LOOP ---
        function startGaugeRenderLoop() {
            function drawGauge(ctx, value, max, color, label) {
                const cx = 90, cy = 90, r = 75;
                ctx.clearRect(0, 0, 180, 180);
                
                // Track Back Arc
                ctx.beginPath();
                ctx.arc(cx, cy, r, 0.75 * Math.PI, 2.25 * Math.PI);
                ctx.strokeStyle = '#1e293b';
                ctx.lineWidth = 10;
                ctx.stroke();

                // Live Value Fill Arc
                let pct = Math.min(value / max, 1);
                ctx.beginPath();
                ctx.arc(cx, cy, r, 0.75 * Math.PI, (0.75 + pct * 1.5) * Math.PI);
                ctx.strokeStyle = color;
                ctx.lineWidth = 12;
                ctx.stroke();
            }

            function render() {
                if (state.role === 'host') { syncDashboardUI(); }
                drawGauge(speedCtx, state.currentSpeed, 60, '#06b6d4', 'KM/H');
                drawGauge(rpmCtx, state.rpm, 7200, '#f59e0b', 'RPM');
                requestAnimationFrame(render);
            }
            requestAnimationFrame(render);
        }
    </script>
</body>
</html>
